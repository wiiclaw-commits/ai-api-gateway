# OpenClaw API Gateway 环境变量

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openclaw_dev
DB_USER=openclaw
DB_PASSWORD=secure_password
DB_POOL_SIZE=20

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=24h

# ============================================
# 管理员配置
# ============================================
ADMIN_EMAIL=admin@openclaw.dev
ADMIN_PASSWORD=admin123

# ============================================
# AI Provider 配置
# ============================================
# 阿里云百炼（必填）
BAILIAN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_API_KEY=sk-your-api-key

# OpenAI（可选）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Anthropic（可选）
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=

# DeepSeek（可选）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=

# ============================================
# OpenClaw 配置
# ============================================
OPENCLAW_HOME=/Users/wiiclaw/.openclaw

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
